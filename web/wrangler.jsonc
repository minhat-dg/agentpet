{
	"compatibility_date": "2026-06-06",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "web",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "agentpet-web",
			"database_id": "local-dev-placeholder"
		}
	],
	"observability": {
		"enabled": true
	}
}