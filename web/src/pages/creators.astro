---
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
import Hero from "../components/Hero.astro";
const DISCORD = "https://discord.gg/kzFJKsZav";
const perks = [
  { icon: "heart", title: "Get adopted", body: "See how many people install and love the pets you made." },
  { icon: "star", title: "Climb the board", body: "Top creators are ranked by downloads, likes, and pets shared." },
  { icon: "users", title: "Build your pack", body: "A creator profile collects all your companions in one place." },
];
---
<Base title="Creators · AgentPet" description="The people behind the pets." active="creators">
  <Hero
    eyebrow="Community creators"
    icon="users"
    title="The people behind"
    accent="the pets"
    lead="A creators leaderboard is on the way. Once community uploads open, you'll be able to follow your favourite pixel artists and climb the ranks."
  >
    <a href={DISCORD} target="_blank" rel="noopener" class="btn-primary !px-6 !py-3"><Icon name="discord" class="h-5 w-5" /> Join the Discord</a>
    <a href="/make" class="btn-ghost !px-6 !py-3"><Icon name="wand" class="h-5 w-5" /> Make a pet</a>
  </Hero>

  <section class="px-4 pt-8">
    <div class="mx-auto grid max-w-6xl gap-5 md:grid-cols-3">
      {perks.map((p) => (
        <div class="card p-7">
          <div class="grid h-12 w-12 place-items-center rounded-2xl bg-brand-50 text-brand-600"><Icon name={p.icon} class="h-6 w-6" /></div>
          <h3 class="mt-4 font-display text-xl font-semibold text-ink">{p.title}</h3>
          <p class="mt-2 text-muted">{p.body}</p>
        </div>
      ))}
    </div>

    <div class="mx-auto mt-8 max-w-6xl">
      <div class="card relative overflow-hidden p-10 text-center">
        <div class="mx-auto grid h-16 w-16 place-items-center rounded-2xl bg-brand-50 text-brand-600"><Icon name="star" class="h-8 w-8" /></div>
        <h2 class="mt-4 font-display text-2xl font-bold text-ink">Leaderboard coming soon</h2>
        <p class="mx-auto mt-2 max-w-md text-muted">Want to be one of the first creators in the library? Bring your pets to the community.</p>
        <a href={DISCORD} target="_blank" rel="noopener" class="btn-primary mt-6 !px-6 !py-3"><Icon name="discord" class="h-5 w-5" /> Join the Discord</a>
      </div>
    </div>
  </section>
</Base>
