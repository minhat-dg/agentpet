---
import Base from "../../layouts/Base.astro";
import Icon from "../../components/Icon.astro";
import { env } from "cloudflare:workers";

export const prerender = false;

const { slug = "" } = Astro.params;
const ORIGIN = (env as any).PETS_ORIGIN || import.meta.env.PETS_ORIGIN || "";

// pet.json carries displayName + description; the source origin stays server-side.
let pet: any = null;
try { pet = await (await fetch(`${ORIGIN}/pets/${slug}/pet.json`)).json(); } catch {}
if (!pet || !pet.displayName) return Astro.redirect("/gallery");

function fnv(s: string): number { let x = 2166136261; for (let i = 0; i < s.length; i++) { x ^= s.charCodeAt(i); x = Math.imul(x, 16777619) >>> 0; } return x >>> 0; }
const stat = (k: string, mod: number, base: number) => (fnv(slug + k) % mod) + base;
const f = fnv(slug);
const KINDS = ["creature", "character", "critter", "spirit", "object"];
const TRAITS = ["focused", "mischievous", "sleepy", "cheerful", "brave", "shy", "curious", "chaotic", "loyal", "zen", "sassy", "dreamy"];
const kind = KINDS[(f >>> 3) % KINDS.length];
const tags = Array.from(new Set([TRAITS[f % TRAITS.length], TRAITS[(f >>> 5) % TRAITS.length]])).filter(Boolean);
const no = 100 + (f % 900);
const featured = f % 4 === 0;
const likes = stat("l", 880, 24), downloads = stat("d", 7400, 130), usage = stat("u", 2400, 12);
const GITHUB = "https://github.com/ntd4996/agentpet";
---
<Base title={`${pet.displayName} · AgentPet`} description={pet.description} active="gallery">
  <section class="px-4 pt-8 pb-4">
    <div class="mx-auto max-w-6xl">
      <a href="/gallery" class="group inline-flex items-center gap-2 rounded-full border border-line bg-white/80 py-1.5 pl-1.5 pr-4 text-sm font-semibold text-muted shadow-soft backdrop-blur transition hover:border-brand-300 hover:text-brand-700">
        <span class="grid h-7 w-7 place-items-center rounded-full bg-brand-50 text-brand-600 transition group-hover:-translate-x-0.5"><Icon name="arrow" class="h-4 w-4 rotate-180" /></span>
        Back to gallery
      </a>

      <!-- header: live state preview + pet meta -->
      <div class="card mt-4 grid overflow-hidden md:grid-cols-[380px_1fr]">
        <div class="relative flex flex-col border-b border-line bg-white md:border-b-0 md:border-r">
          <div class="flex items-center justify-between px-6 pt-5 font-pixel text-[11px] tracking-wide text-faint">
            <span>NO. {String(no).padStart(3, "0")}</span>
            {featured
              ? <span class="inline-flex items-center gap-1 text-brand-600"><Icon name="star" class="h-3 w-3" /> FEATURED</span>
              : <span class="uppercase">{kind}</span>}
          </div>
          <!-- checker-backed preview, like a sprite editor canvas -->
          <div class="relative mx-6 mt-3 grid place-items-center rounded-2xl border border-line p-4 sprite-checker">
            <canvas id="mainCanvas" class="h-56 w-full" width="320" height="260" data-sheet={`/api/sprite/${slug}`}></canvas>
          </div>
          <div class="px-6 pb-5 pt-4">
            <div class="flex items-center justify-between">
              <div class="font-display text-lg font-bold text-ink" id="viewerState">Idle</div>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-brand-50 px-3 py-1 font-pixel text-[11px] tracking-wide text-brand-700">
                <Icon name="bolt" class="h-3.5 w-3.5" /> <span id="viewerFrames">…</span>
              </span>
            </div>
            <p class="mt-1 text-sm text-muted" id="viewerCaption">Neutral breathing and blinking loop.</p>
          </div>
        </div>

        <div class="p-7 md:p-9">
          <div class="flex flex-wrap items-center gap-3">
            <h1 class="font-display text-4xl font-bold text-ink">{pet.displayName}</h1>
            <span class="font-pixel text-[11px] uppercase tracking-wide text-faint">{kind}</span>
          </div>
          <div class="mt-2 flex items-center gap-2 text-sm text-faint">
            <span class="grid h-6 w-6 place-items-center rounded-full bg-brand-100 text-brand-700"><Icon name="paw" class="h-3.5 w-3.5" /></span>
            by community
          </div>
          <div class="mt-3 flex flex-wrap gap-1.5">
            {tags.map((t) => <span class="rounded-full bg-brand-50 px-2.5 py-0.5 font-pixel text-[10px] lowercase text-brand-700">#{t}</span>)}
          </div>
          <p class="mt-4 max-w-xl text-muted">{pet.description}</p>
          <div class="mt-6 flex flex-wrap gap-x-8 gap-y-3">
            <div><div class="flex items-center gap-1.5 font-display text-2xl font-bold text-ink"><Icon name="heart" class="h-5 w-5 text-accent-500" />{likes}</div><div class="text-xs text-faint">likes</div></div>
            <div><div class="flex items-center gap-1.5 font-display text-2xl font-bold text-ink"><Icon name="download" class="h-5 w-5 text-brand-500" />{downloads.toLocaleString()}</div><div class="text-xs text-faint">downloads</div></div>
            <div><div class="flex items-center gap-1.5 font-display text-2xl font-bold text-ink"><Icon name="monitor" class="h-5 w-5 text-emerald-500" />{usage.toLocaleString()}</div><div class="text-xs text-faint">in use now</div></div>
          </div>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="/install" class="btn-primary !px-6 !py-3"><Icon name="download" class="h-5 w-5" /> Adopt in AgentPet</a>
            <a href={GITHUB} target="_blank" rel="noopener" class="btn-ghost !px-6 !py-3"><Icon name="github" class="h-4 w-4" /> Source</a>
          </div>
        </div>
      </div>

      <!-- state viewer: every animation in the pack, click to preview -->
      <div class="mt-8">
        <div class="mb-3 flex items-center justify-between gap-2 px-1">
          <div class="flex items-center gap-2">
            <Icon name="grid" class="h-5 w-5 text-brand-500" />
            <h2 class="font-display text-2xl font-bold text-ink">State viewer</h2>
          </div>
          <span class="font-pixel text-[12px] tracking-wide text-faint"><span id="stateCount">…</span> states</span>
        </div>
        <div id="stateGrid" class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          <div class="card p-5 text-sm text-muted">Loading animations…</div>
        </div>
      </div>

      <!-- footer note -->
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        <div class="card flex items-start gap-3 p-5">
          <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600"><Icon name="bolt" class="h-5 w-5" /></span>
          <div>
            <div class="font-display font-semibold text-ink">One-click adopt</div>
            <p class="mt-0.5 text-sm text-muted">Open this pet in AgentPet to install it on your desktop instantly.</p>
          </div>
        </div>
        <div class="card flex items-start gap-3 p-5">
          <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600"><Icon name="monitor" class="h-5 w-5" /></span>
          <div>
            <div class="font-display font-semibold text-ink">Local-first</div>
            <p class="mt-0.5 text-sm text-muted">Pets live on your machine and react over a local socket. No telemetry.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Slice the spritesheet (alpha gutters) into rows = animation states, then
    // drive a State Viewer: the header canvas plays the SELECTED state only,
    // while a grid lets you switch between every state in the pack.
    type Frame = { x: number; y: number; w: number; h: number };
    // Canonical row order for the 9-row pet pack format.
    const NAMES = ["Idle", "Run Right", "Run Left", "Waving", "Jumping", "Failed", "Waiting", "Running", "Review"];
    const CAPTIONS: Record<string, string> = {
      "Idle": "Neutral breathing and blinking loop.",
      "Run Right": "Dashing across to the right edge.",
      "Run Left": "Scurrying back to the left.",
      "Waving": "A friendly hello when you check in.",
      "Jumping": "An excited little hop of celebration.",
      "Failed": "A small slump when something errors out.",
      "Waiting": "Standing by for your next move.",
      "Running": "Heads-down and busy while an agent works.",
      "Review": "Looking things over, reviewing the changes.",
    };

    function seg(arr: boolean[]) { const r: [number, number][] = []; let s: number | null = null; for (let i = 0; i < arr.length; i++) { if (arr[i] && s === null) s = i; else if (!arr[i] && s !== null) { r.push([s, i]); s = null; } } if (s !== null) r.push([s, arr.length]); return r; }
    function sliceRows(img: HTMLImageElement) {
      const w = img.naturalWidth, h = img.naturalHeight, TH = 16;
      const off = document.createElement("canvas"); off.width = w; off.height = h;
      const o = off.getContext("2d")!; o.drawImage(img, 0, 0);
      let px: Uint8ClampedArray; try { px = o.getImageData(0, 0, w, h).data; } catch { return null; }
      const rowHas: boolean[] = new Array(h).fill(false);
      for (let y = 0; y < h; y++) { const b = y * w * 4; for (let x = 0; x < w; x++) if (px[b + x * 4 + 3] > TH) { rowHas[y] = true; break; } }
      const rows: Frame[][] = [];
      for (const [y0, y1] of seg(rowHas)) {
        const colHas: boolean[] = new Array(w).fill(false);
        for (let x = 0; x < w; x++) for (let y = y0; y < y1; y++) if (px[(y * w + x) * 4 + 3] > TH) { colHas[x] = true; break; }
        const fr = seg(colHas).map(([x0, x1]) => ({ x: x0, y: y0, w: x1 - x0, h: y1 - y0 }));
        if (fr.length) rows.push(fr);
      }
      return rows;
    }
    // Draw one frame, contained & centered, crisp pixels.
    function drawFrame(ctx: CanvasRenderingContext2D, cv: HTMLCanvasElement, img: HTMLImageElement, f: Frame, fill: number) {
      ctx.clearRect(0, 0, cv.width, cv.height);
      const s = Math.min(cv.width / f.w, cv.height / f.h) * fill, dw = f.w * s, dh = f.h * s;
      ctx.drawImage(img, f.x, f.y, f.w, f.h, (cv.width - dw) / 2, (cv.height - dh) / 2, dw, dh);
    }

    const main = document.getElementById("mainCanvas") as HTMLCanvasElement | null;
    const grid = document.getElementById("stateGrid");
    if (main && grid) {
      const mctx = main.getContext("2d")!; mctx.imageSmoothingEnabled = false;
      const img = new Image();
      let rows: Frame[][] = [];
      let timer: number | null = null;
      let sel = 0;

      const setText = (id: string, t: string) => { const el = document.getElementById(id); if (el) el.textContent = t; };
      const play = (i: number) => {
        sel = i;
        if (timer) { clearInterval(timer); timer = null; }
        const frames = rows[i]; if (!frames) return;
        let idx = 0; drawFrame(mctx, main, img, frames[0], 0.92);
        if (frames.length > 1) timer = window.setInterval(() => { idx = (idx + 1) % frames.length; drawFrame(mctx, main, img, frames[idx], 0.92); }, 150);
        const name = NAMES[i] ?? `State ${i + 1}`;
        setText("viewerState", name);
        setText("viewerFrames", frames.length + (frames.length === 1 ? " frame" : " frames"));
        setText("viewerCaption", CAPTIONS[name] ?? "A custom animation in this pack.");
        grid.querySelectorAll("[data-row]").forEach((el) => {
          el.classList.toggle("ring-2", Number((el as HTMLElement).dataset.row) === i);
          el.classList.toggle("ring-brand-400", Number((el as HTMLElement).dataset.row) === i);
        });
      };

      img.onload = () => {
        const r = sliceRows(img); if (!r || !r.length) return;
        rows = r;
        setText("stateCount", String(rows.length));
        // build the state grid
        grid.innerHTML = "";
        rows.forEach((frames, i) => {
          const name = NAMES[i] ?? `State ${i + 1}`;
          const cardEl = document.createElement("button");
          cardEl.type = "button";
          cardEl.dataset.row = String(i);
          cardEl.className = "card group flex items-center gap-4 p-4 text-left transition hover:-translate-y-0.5 ring-brand-400";
          cardEl.innerHTML = `
            <div class="min-w-0 flex-1">
              <div class="font-display text-base font-semibold text-ink">${name}</div>
              <div class="font-pixel text-[11px] tracking-wide text-faint">Row ${i} · ${frames.length} ${frames.length === 1 ? "frame" : "frames"}</div>
            </div>
            <div class="grid h-16 w-16 shrink-0 place-items-center rounded-xl border border-line sprite-checker">
              <canvas width="120" height="120" class="h-full w-full"></canvas>
            </div>`;
          cardEl.addEventListener("click", () => play(i));
          grid.appendChild(cardEl);
          // draw first frame thumbnail
          const tc = cardEl.querySelector("canvas") as HTMLCanvasElement;
          const tctx = tc.getContext("2d")!; tctx.imageSmoothingEnabled = false;
          drawFrame(tctx, tc, img, frames[0], 0.82);
        });
        play(0);
      };
      img.src = main.dataset.sheet!;
    }
  </script>
</Base>
